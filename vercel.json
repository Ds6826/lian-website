{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": { "includeFiles": ["*.html"] }
    },
    { "src": "app.js", "use": "@vercel/static" },
    { "src": "clerk-loader.js", "use": "@vercel/static" },
    { "src": "script.js", "use": "@vercel/static" },
    { "src": "governor.js", "use": "@vercel/static" },
    { "src": "memory-governor.html", "use": "@vercel/static" },
    { "src": "product.html", "use": "@vercel/static" },
    { "src": "compliance.html", "use": "@vercel/static" },
    { "src": "security.html", "use": "@vercel/static" },
    { "src": "sdks.html", "use": "@vercel/static" },
    { "src": "compare.html", "use": "@vercel/static" },
    { "src": "pricing.html", "use": "@vercel/static" },
    { "src": "docs.html", "use": "@vercel/static" },
    { "src": "solutions.html", "use": "@vercel/static" },
    { "src": "solutions-financial-services.html", "use": "@vercel/static" },
    { "src": "solutions-healthcare.html", "use": "@vercel/static" },
    { "src": "solutions-legal.html", "use": "@vercel/static" },
    { "src": "console-api.js", "use": "@vercel/static" },
    { "src": "app.css", "use": "@vercel/static" },
    { "src": "favicon.svg", "use": "@vercel/static" },
    { "src": "styles.css", "use": "@vercel/static" },
    { "src": "pages.css", "use": "@vercel/static" },
    { "src": "lians.css", "use": "@vercel/static" },
    { "src": "lians.js", "use": "@vercel/static" },
    { "src": "governor.css", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/memory-governor", "dest": "/memory-governor.html" },
    { "src": "/product", "dest": "/product.html" },
    { "src": "/compliance", "dest": "/compliance.html" },
    { "src": "/security", "dest": "/security.html" },
    { "src": "/sdks", "dest": "/sdks.html" },
    { "src": "/compare", "dest": "/compare.html" },
    { "src": "/pricing", "dest": "/pricing.html" },
    { "src": "/docs", "dest": "/docs.html" },
    { "src": "/solutions", "dest": "/solutions.html" },
    { "src": "/solutions/financial-services", "dest": "/solutions-financial-services.html" },
    { "src": "/solutions/healthcare", "dest": "/solutions-healthcare.html" },
    { "src": "/solutions/legal", "dest": "/solutions-legal.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/api/index.js" }
  ]
}
