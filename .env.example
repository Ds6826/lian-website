# Server
PORT=8000
BASE_URL=http://localhost:8000
SESSION_SECRET=replace_with_a_long_random_string

# Clerk — https://dashboard.clerk.com
# Use Clerk development keys for localhost. Use production keys/custom domains
# only for your deployed domain, such as https://www.lians.ai.
CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_SECRET_KEY=sk_test_
# Plan ID from Clerk Dashboard > Subscriptions (fill in when billing is configured)
CLERK_BILLING_PLAN_ID=

# Lians memory (MCP server in .mcp.json / agent integrations)
# Get a key at https://www.lians.ai/login, or self-host:
#   git clone https://github.com/ebeirne/Lians2 && docker compose up --build
LIANS_URL=https://agentmem-lotus.fly.dev
LIANS_API_KEY=
LIANS_AGENT_ID=lian-website-dev
